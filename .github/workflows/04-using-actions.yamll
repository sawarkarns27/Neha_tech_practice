name : 04 - Using Actions
on : push

jobs : 
  build : 
    runs-on : ubuntu-latest
    steps :
      - name : Checkout Code
        uses : actions/checkout@v4
      - name : print list of folders/files
        run : |
          ls 
          cd sample-app
          ls
      - name : Setup Node
        uses : actions/setup-node@v4
        with : 
          node-version: '20.x'
      - name : Install Dependencies
        run : |
          cd sample-app 
          npm install